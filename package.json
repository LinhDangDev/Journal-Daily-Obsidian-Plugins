{
    "name": "daily-journal",
    "version": "1.0.0",
    "description": "Create, organize, and manage daily journal entries with customizable templates, mood tracking, and date-based folder structure.",
    "main": "main.js",
    "type": "module",
    "scripts": {
        "dev": "node esbuild.config.mjs",
        "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
        "version": "node version-bump.mjs && git add manifest.json versions.json"
    },
    "keywords": [
        "obsidian",
        "journal",
        "daily-notes"
    ],
    "license": "MIT",
    "devDependencies": {
        "@types/node": "^16.11.6",
        "esbuild": "0.25.5",
        "tslib": "2.4.0",
        "typescript": "^5.8.3"
    },
    "dependencies": {
        "obsidian": "latest"
    }
}
