{
    "name": "daily-journal",
    "version": "1.0.0",
    "description": "Create, organize, and manage daily journal entries with customizable templates, mood tracking, and date-based folder structure.",
    "main": "main.js",
    "type": "module",
    "scripts": {
        "dev": "node esbuild.config.mjs",
        "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
        "version": "node version-bump.mjs && git add manifest.json versions.json",
        "lint": "eslint src/",
        "lint:fix": "eslint src/ --fix",
        "format": "prettier --write src/",
        "format:check": "prettier --check src/",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "keywords": [
        "obsidian",
        "journal",
        "daily-notes"
    ],
    "license": "MIT",
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/node": "^16.11.6",
        "esbuild": "0.25.5",
        "eslint": "^10.0.2",
        "eslint-config-prettier": "^10.1.8",
        "prettier": "^3.8.1",
        "tslib": "2.4.0",
        "typescript": "^5.8.3",
        "typescript-eslint": "^8.56.1"
    },
    "dependencies": {
        "obsidian": "latest"
    }
}
